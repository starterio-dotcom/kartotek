# Másold .env-be és töltsd ki. A .env nem kerül verziókövetésbe.

# --- Backend (apps/api) ---
API_PORT=3001
# Egy-node-os replica set (lásd docker-compose.yml); a tranzakciókhoz kell.
MONGO_URI=mongodb://localhost:27017/kartotek?replicaSet=rs0&directConnection=true
NODE_ENV=development

# --- Frontend (apps/web) ---
# A Vite a böngészőbe csak a VITE_ prefixű változókat engedi.
# Az API-útvonalak már tartalmazzák a /api előtagot, ezért ez a BASE-origin.
# Azonos origin (éles, reverse-proxy mögött): hagyd ÜRESEN. Kereszt-origin dev: a teljes URL.
VITE_API_URL=http://localhost:3001

# --- Biztonság (Fázis 7) ---
# Engedélyezett CORS-originek vesszővel; üresen ÉLES módban TILTÓ a CORS (dev: bármely).
CORS_ORIGIN=
# Rate limit: max kérés / időablak egy IP-ről (0 = ki).
RATE_LIMIT_MAX=300
RATE_LIMIT_ABLAK_MS=60000
# A tárhely helye (éles compose: /data/tarhely kötet).
TARHELY_DIR=./.tarhely

# --- Hitelesítés: backend (Fázis 7–8) ---
# 'dev' = x-felhasznalo-email fejléc (CSAK fejlesztés), 'oidc' = valódi SSO (JWKS).
AUTH_PROVIDER=dev
# OIDC módban kötelező: az IdP issuer-e és a JWKS-végpont (pl. Keycloak):
OIDC_ISSUER=http://localhost:8088/realms/kartotek
OIDC_JWKS_URI=http://localhost:8088/realms/kartotek/protocol/openid-connect/certs
# Audience-ellenőrzés opcionális (Keycloak access tokenben alapból nincs client-aud → hagyd üresen):
OIDC_AUDIENCE=
OIDC_EMAIL_CLAIM=email
# Ismeretlen (de hitelesített) e-mail → jogosultság nélküli felhasználó létrehozása:
OIDC_AUTO_PROVISION=false

# --- Hitelesítés: frontend (Fázis 8) ---
# 'dev' = felhasználóváltó, 'oidc' = valódi login (Authorization Code + PKCE).
VITE_AUTH_MODE=dev
VITE_OIDC_AUTHORITY=http://localhost:8088/realms/kartotek
VITE_OIDC_CLIENT_ID=kartotek-web

# --- Éles compose (docker-compose.prod.yml) ---
WEB_PORT=8080
