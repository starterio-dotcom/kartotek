      "default": "./dist/tipusok.js"
    },
    "./allapotgep": {
      "development": "./src/allapotgep/index.ts",
      "types": "./dist/allapotgep/index.d.ts",
      "default": "./dist/allapotgep/index.js"
    },
    "./jogosultsag": {
      "development": "./src/jogosultsag/index.ts",
      "types": "./dist/jogosultsag/index.d.ts",
      "default": "./dist/jogosultsag/index.js"
    },
    "./kapcsolat": {
      "development": "./src/kapcsolat/index.ts",
      "types": "./dist/kapcsolat/index.d.ts",
      "default": "./dist/kapcsolat/index.js"
    },
    "./azonosito": {
      "development": "./src/azonosito/index.ts",
      "types": "./dist/azonosito/index.d.ts",
      "default": "./dist/azonosito/index.js"
    },
    "./riport": {
      "development": "./src/riport/index.ts",
      "types": "./dist/riport/index.d.ts",
      "default": "./dist/riport/index.js"
    },
    "./semak": {
      "development": "./src/semak/index.ts",
      "types": "./dist/semak/index.d.ts",
      "default": "./dist/semak/index.js"
    }
